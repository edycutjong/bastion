# ── Bastion (Vouch) — environment ──────────────────────────────────────────
# Copy to .env.local for Next.js (server-only) and .env for scripts. NEVER commit real values.

# Demo mode is ON by default. Set to "false" so /api/revoke broadcasts a real
# revoke TransactionV1 and /api/check settles via the real x402 facilitator.
# See LIVE_TESTNET.md.
BASTION_DEMO=true
# Signing key algorithm for casper-js-sdk (ed25519 | secp256k1)
CASPER_KEY_ALGO=ed25519
# Price charged per live pay-to-check (x402).
X402_CHECK_PRICE=$0.001

# CSPR.cloud access token — obtain at https://cspr.cloud/ . Used as: Authorization: $CSPR_CLOUD_API_KEY
# Do NOT put this in any client/browser bundle.
CSPR_CLOUD_API_KEY=

# Casper Testnet (CAIP-2 casper:casper-test)
CASPER_NETWORK=casper-test
CASPER_NODE_RPC=https://node.testnet.cspr.cloud/rpc
CASPER_CHAIN_NAME=casper-test

# Issuer/admin signing key (Testnet-only keypairs under data/keys/ for the deterministic demo).
CASPER_ISSUER_SECRET_KEY_PATH=./data/keys/issuer_secret_key.pem

# Bastion contract (Odra, upgradable — Merkle root + nullifier set).
BASTION_CONTRACT_HASH=

# x402 facilitator (CEP-18 micropayments for proof-checks).
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
X402_ASSET_PACKAGE=
X402_PAYEE_ADDRESS=
X402_CAIP2_CHAIN_ID=casper:casper-test

# ── Optional overrides (sensible defaults; uncomment only to tune) ────────────
# CASPER_CALL_PAYMENT_MOTES=5000000000        # gas limit per contract entry-point call (default 5 CSPR)
# BASTION_INSTALL_MOTES=500000000000          # gas limit for the RPC contract install via pnpm deploy:rpc (default 500 CSPR)
# BASTION_WASM_PATH=contract/wasm/Bastion.wasm # override the wasm path for pnpm deploy:rpc
# BASTION_HOLDER=mallory                       # which seeded holder pnpm lifecycle revokes (default mallory)

# Real Claude compliance officer over revocation events (optional). With a key,
# POST /api/console includes a genuine LLM review (memos + severity + privacy
# attestation). Without one, officerReview is null and the deterministic
# pipeline is unchanged.
ANTHROPIC_API_KEY=
# BASTION_OFFICER_MODEL=claude-haiku-4-5
